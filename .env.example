# Sentium - Docker Compose configuration
# ----------------------------------------------------------------------------------
# Copy this file to ".env" and adjust the values before running `docker compose up`.
#   bash / macOS / Linux : cp .env.example .env
#   PowerShell (Windows) : Copy-Item .env.example .env
#
# Only the values under "Secrets" strictly need changing for a local run; everything
# else has a sensible default. See docs/installation.md for the full walkthrough.
# ----------------------------------------------------------------------------------

# --- Secrets (CHANGE THESE) -------------------------------------------------------
# Each secret should be a unique, random value. Generate one with:
#   bash / macOS / Linux : openssl rand -base64 32
#   PowerShell (Windows) : [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 }))

# SQL Server 'sa' password. Must satisfy SQL Server complexity rules
# (>= 8 chars, with at least three of: uppercase, lowercase, digit, symbol).
SQL_PASSWORD=Your_Strong_Password123

# Pre-shared key for internal service-to-service calls (the X-Internal-Token header).
# Shared by every service; calls between them fail if they disagree.
INTERNAL_API_KEY=change-me-internal-api-key

# OIDC client secret shared between the Gateway BFF and Identity (the "gateway-bff" client).
GATEWAY_BFF_SECRET=change-me-gateway-bff-secret

# OIDC client secret for the internal service-worker (client_credentials) client.
SERVICE_WORKER_SECRET=change-me-service-worker-secret

# Qdrant API key. Can be any non-empty string - the Qdrant client always sends one,
# so it must match between the qdrant server and the services that talk to it.
QDRANT_API_KEY=change-me-qdrant-key

# Password for the Gateway's TLS dev certificate. Must match the value passed to
# `dotnet dev-certs https -ep certs/sentium.pfx -p <CERT_PASSWORD>` (see the install guide).
CERT_PASSWORD=change-me-cert-password

# --- Published ports --------------------------------------------------------------
# Host ports the stack is exposed on. Change them only if something else already uses
# these ports; the defaults match the URLs printed in the README and install guide.

# HTTPS port the Gateway (the browser-facing API / BFF) is published on.
GATEWAY_HTTPS_PORT=8443
# HTTP port the Identity server (OIDC issuer + login UI) is published on.
IDENTITY_HTTP_PORT=8081
# HTTP port the portal SPA is served on.
PORTAL_PORT=5173

# --- Models (pulled into Ollama on first run) -------------------------------------
# These must be valid Ollama tags. The chat model can be swapped for any installed
# model (e.g. qwen3:4b); the embedding model must stay 768-dimensional to match the
# RAG vector size (nomic-embed-text). The defaults mirror the Aspire AppHost.

SENTIUM_MODEL=gemma4:e4b
SENTIUM_EMBEDDING_MODEL=nomic-embed-text

# --- Sandbox ----------------------------------------------------------------------

# Per-job working directory for the code sandbox. Because the Sandbox spawns sibling worker
# containers via the host Docker daemon, this path must be IDENTICAL on the host and inside the
# Sandbox container (the value is used as both the bind source and target). On Windows, use a
# path inside your WSL2 distro.
SANDBOX_JOBS_DIR=/tmp/sentium-sandbox

# --- Blob storage (Azurite emulator, well-known dev credentials) ------------------
# These are Azurite's public, well-known development credentials - safe to commit and
# the same ones the Aspire emulator uses. Only the blob endpoint is used by Sentium.

AZURITE_CONNECTION=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://azurite:10000/devstoreaccount1;QueueEndpoint=http://azurite:10001/devstoreaccount1;TableEndpoint=http://azurite:10002/devstoreaccount1;
