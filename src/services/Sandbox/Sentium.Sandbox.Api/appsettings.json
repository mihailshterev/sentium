{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Sandbox": {
    "PythonImage": "python:3.12-slim",
    "NodeImage": "node:22-alpine",
    "MemoryLimitBytes": 268435456,
    "CpuLimit": 0.5,
    "ExecutionTimeoutSeconds": 30,
    "PidsLimit": 128,
    "NoFileLimitSoft": 64,
    "NoFileLimitHard": 128,
    "JobBaseDirectory": "",
    "MaxCodeSizeBytes": 524288,
    "MaxFileContextEntries": 20,
    "MaxFileContentBytes": 1048576,
    "PullImageIfMissing": true,
    "ReadonlyRootFs": true,
    "SeccompProfile": "",
    "TmpfsSizeMb": "64m",
    "DockerHost": ""
  }
}
