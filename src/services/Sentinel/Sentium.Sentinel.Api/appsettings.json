{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pdp": {
    "RateLimitMaxRequests": 120,
    "RateLimitWindowSeconds": 60,
    "SemanticIntentCheckEnabled": true,
    "IntentCheckModel": "llama3.2:1b",
    "ForbiddenActions": ["delete", "drop", "truncate", "purge", "override", "bypass", "escalate"],
    "ProtectedResourcePrefixes": [
      "/etc/",
      "/sys/",
      "/proc/",
      "C:\\Windows\\",
      ".env",
      "appsettings",
      "secret",
      "private_key"
    ]
  }
}
