{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Pdp": {
    "ForbiddenActions": ["delete", "drop", "truncate", "purge", "override", "bypass", "escalate"],
    "ProtectedResourcePrefixes": [
      "/etc/",
      "/sys/",
      "/proc/",
      "C:\\Windows\\",
      ".env",
      "appsettings",
      "secret",
      "private_key"
    ]
  }
}
