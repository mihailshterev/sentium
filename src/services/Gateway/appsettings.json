{
  "Identity": {
    "Authority": "https+http://identity",
    "GatewayBffSecret": ""
  },
  "Frontend": {
    "Origin": "http://localhost:5173"
  },
  "ReverseProxy": {
    "Routes": {
      "agent-runtime": {
        "ClusterId": "agent-runtime",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/agent-runtime/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/agent-runtime" }]
      },
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/identity" }]
      },
      "sentinel": {
        "ClusterId": "sentinel",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/sentinel/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/sentinel" }]
      },
      "watchdog": {
        "ClusterId": "watchdog",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/watchdog/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/watchdog" }]
      },
      "sandbox": {
        "ClusterId": "sandbox",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/sandbox/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api" }]
      },
      "registry": {
        "ClusterId": "registry",
        "AuthorizationPolicy": "authenticated",
        "Match": {
          "Path": "/api/registry/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/registry" }]
      }
    },
    "Clusters": {
      "agent-runtime": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://agent-runtime"
          }
        }
      },
      "identity": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://identity"
          }
        }
      },
      "sentinel": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://sentinel"
          }
        }
      },
      "watchdog": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://watchdog"
          }
        }
      },
      "sandbox": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://sandbox"
          }
        }
      },
      "registry": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://registry"
          }
        }
      }
    }
  }
}
