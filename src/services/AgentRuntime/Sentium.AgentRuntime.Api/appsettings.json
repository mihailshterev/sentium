{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Rag": {
    "CollectionName": "knowledge_base",
    "EmbeddingModelName": "nomic-embed-text",
    "ChunkSize": 500,
    "ChunkOverlap": 50,
    "DefaultTopK": 5,
    "ScoreThreshold": 0.5,
    "VectorSize": 768
  }
}
