{
  "ReverseProxy": {
    "Routes": {
      "agent-runtime": {
        "ClusterId": "agent-runtime",
        "Match": {
          "Path": "/agents/{**catch-all}"
        }
      },
      "assistant-route": {
        "ClusterId": "agent-runtime",
        "Match": {
          "Path": "/assistant/{**catch-all}"
        }
      },
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "sentinel": {
        "ClusterId": "sentinel",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "agent-runtime": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://agent-runtime"
          }
        }
      },
      "identity": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://identity"
          }
        }
      },
      "sentinel": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://sentinel"
          }
        }
      }
    }
  }
}
