{
  "ReverseProxy": {
    "Routes": {
      "agent-runtime": {
        "ClusterId": "agent-runtime",
        "Match": {
          "Path": "/api/agent-runtime/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/agent-runtime" }]
      },
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/identity" }]
      },
      "sentinel": {
        "ClusterId": "sentinel",
        "Match": {
          "Path": "/api/sentinel/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/sentinel" }]
      },
      "watchdog": {
        "ClusterId": "watchdog",
        "Match": {
          "Path": "/api/watchdog/{**catch-all}"
        },
        "Transforms": [{ "PathRemovePrefix": "/api/watchdog" }]
      }
    },
    "Clusters": {
      "agent-runtime": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://agent-runtime"
          }
        }
      },
      "identity": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://identity"
          }
        }
      },
      "sentinel": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://sentinel"
          }
        }
      },
      "watchdog": {
        "Destinations": {
          "destination1": {
            "Address": "http+https://watchdog"
          }
        }
      }
    }
  }
}
